---
import Layout from "@/layouts/Layout.astro";
import HeaderSection from "@/components/header/HeaderSection.astro";
import HeroSection from "@/components/hero/HeroSection.astro";
import ProjectsSection from "@/components/projects/ProjectsSection.astro";
import Skills from "@/components/skills/SkillsSection.astro";
import AboutMeSection from "@/components/aboutMe/AboutMeSection.astro";
import Experience from "@/components/experience/ExperienceSection.astro";
import ContactMeSection from "@/components/contact/ContactMeSection.astro";
import Footer from "@/components/footer/Footer.astro";
---

<Layout
    title="Carlos Guijosa | Desarrollador Full Stack · Blockchain · IA"
    description="Portafolio de Carlos Guijosa, ingeniero y desarrollador full-stack. Co-Founder de NoMaTech. Especializado en automatización inteligente, blockchain y soluciones con IA en Morelia, Michoacán."
>
    <HeaderSection />
    <main>
        <HeroSection />
        <ProjectsSection />
        <Experience />
        <Skills />
        <ContactMeSection />
        <AboutMeSection />
    </main>
    <Footer />
