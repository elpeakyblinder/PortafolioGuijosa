---
const navItems = [
    { label: "Inicio", id: "inicio" },
    { label: "Proyectos", id: "projects" },
    { label: "Experiencia", id: "experience" },
    { label: "Habilidades", id: "skills" },
    { label: "Contacto", id: "contact" },
    { label: "Sobre mí", id: "aboutMe" },
];
---

<header id="main-header" class="main-header">
    <div class="header-inner">
        <a href="/" class="logo">
            &lt;<span class="logo-accent">Guijosa</span>/&gt;
        </a>

        <!-- Desktop nav -->
        <nav class="desktop-nav">
            {navItems.map(item => (
                <a href={`#${item.id}`} class="nav-link" data-section={item.id}>
                    {item.label}
                </a>
            ))}
        </nav>

        <!-- Desktop social links -->
        <div class="social-links desktop-only">
            <a href="https://github.com/elpeakyblinder" target="_blank" rel="noopener noreferrer" aria-label="Perfil de GitHub de Carlos Guijosa">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </a>
            <a href="https://linkedin.com/in/carlos-guijosa" target="_blank" rel="noopener noreferrer" aria-label="Perfil de LinkedIn de Carlos Guijosa">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="mailto:devcharlying@gmail.com" aria-label="Enviar correo a Carlos Guijosa">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </a>
        </div>

        <!-- Hamburger button (mobile) -->
        <button id="menu-toggle" class="menu-btn" aria-label="Menu">
            <span class="bar bar-1"></span>
            <span class="bar bar-2"></span>
            <span class="bar bar-3"></span>
        </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="mobile-menu">
        <nav class="mobile-nav">
            {navItems.map(item => (
                <a href={`#${item.id}`} class="mobile-link" data-section={item.id}>
                    {item.label}
                </a>
            ))}
            <div class="social-links mobile-socials">
                <a href="https://github.com/elpeakyblinder" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                </a>
                <a href="https://linkedin.com/in/carlos-guijosa" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
                <a href="mailto:devcharlying@gmail.com" aria-label="Correo">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </a>
            </div>
        </nav>
    </div>
</header>

<style>
    .main-header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 10;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid transparent;
        background: rgba(34, 40, 49, 0.5);
        transition: background 0.3s, border-color 0.3s;
        font-weight: 700;
        font-size: 1.125rem;
    }

    .main-header.scrolled {
        border-bottom-color: var(--clr-accent-transparent);
        background: rgba(34, 40, 49, 0.55);
    }

    .header-inner {
        max-width: 100%;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2rem;
        color: var(--clr-text-secundary);
    }

    .logo {
        color: var(--clr-text-secundary);
        text-decoration: none;
    }

    .logo-accent {
        color: var(--clr-accent);
    }

    /* Desktop nav */
    .desktop-nav {
        display: none;
        align-items: center;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .desktop-nav {
            display: flex;
        }
    }

    /* Social links */
    .social-links {
        display: flex;
        gap: 1rem;
    }

    .social-links a {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--clr-text-secundary);
        transition: color 0.3s;
    }

    .social-links a:hover {
        color: var(--clr-accent);
    }

    .desktop-only {
        display: none;
    }

    @media (min-width: 768px) {
        .desktop-only {
            display: flex;
        }
    }

    /* Hamburger button */
    .menu-btn {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 9999px;
        background: var(--clr-dark-space);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
        border: none;
        cursor: pointer;
        z-index: 50;
        transition: transform 0.3s;
    }

    .menu-btn:hover {
        transform: scale(1.05);
    }

    .menu-btn:active {
        transform: scale(0.9);
    }

    @media (min-width: 768px) {
        .menu-btn {
            display: none;
        }
    }

    .bar {
        display: block;
        width: 1.5rem;
        height: 2px;
        background: var(--clr-accent);
        border-radius: 2px;
        transition: transform 0.3s cubic-bezier(0.68, -0.6, 0.32, 1.6),
                    opacity 0.2s;
        transform-origin: center;
    }

    .bar-1 { margin-bottom: 6px; }
    .bar-2 { margin-bottom: 6px; }

    /* Hamburger → X */
    .menu-btn.open .bar-1 {
        transform: rotate(45deg) translate(3px, 5px);
    }
    .menu-btn.open .bar-2 {
        opacity: 0;
        transform: scale(0);
    }
    .menu-btn.open .bar-3 {
        transform: rotate(-45deg) translate(3px, -5px);
    }

    /* Mobile menu */
    .mobile-menu {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        height: 100dvh;
        background: var(--clr-dark-space);
        z-index: 40;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(12px);
        opacity: 0;
        transform: translateY(-50px) scale(0.95);
        pointer-events: none;
        transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .mobile-menu.open {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
    }

    .mobile-nav {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        gap: 2.5rem;
        font-size: 1.875rem;
        font-weight: 600;
        color: var(--clr-text-secundary);
    }

    .mobile-link {
        color: var(--clr-text-secundary);
        text-decoration: none;
        transition: color 0.3s, transform 0.2s;
        opacity: 0;
        transform: translateY(30px);
        transition: color 0.3s, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                    opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .mobile-menu.open .mobile-link {
        opacity: 1;
        transform: translateY(0);
    }

    /* Staggered animation for mobile links */
    .mobile-link:nth-child(1) { transition-delay: 0.05s; }
    .mobile-link:nth-child(2) { transition-delay: 0.1s; }
    .mobile-link:nth-child(3) { transition-delay: 0.15s; }
    .mobile-link:nth-child(4) { transition-delay: 0.2s; }
    .mobile-link:nth-child(5) { transition-delay: 0.25s; }
    .mobile-link:nth-child(6) { transition-delay: 0.3s; }

    .mobile-menu:not(.open) .mobile-link {
        transition-delay: 0s;
    }

    .mobile-link:hover {
        color: var(--clr-accent);
        transform: scale(1.1);
    }

    .mobile-link:active {
        transform: scale(0.95);
    }

    .mobile-socials {
        margin-top: 3rem;
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        transition-delay: 0s;
    }

    .mobile-menu.open .mobile-socials {
        opacity: 1;
        transform: translateY(0);
        transition-delay: 0.35s;
    }
</style>

<script>
    const header = document.getElementById("main-header");
    const menuBtn = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    const sectionIds = ["inicio", "projects", "experience", "skills", "contact", "aboutMe"];

    // Scroll → header bg
    function handleScroll() {
        if (!header) return;
        if (window.scrollY > 0) {
            header.classList.add("scrolled");
        } else {
            header.classList.remove("scrolled");
        }
    }

    // Scroll spy → active nav link
    function handleScrollSpy() {
        const scrollY = window.scrollY;
        const headerOffset = 150;
        let currentSection = "inicio";

        for (const id of sectionIds) {
            const section = document.getElementById(id);
            if (!section) continue;
            const sectionTop = section.offsetTop - headerOffset;
            const sectionHeight = section.offsetHeight;
            if (scrollY >= sectionTop && scrollY < sectionTop + sectionHeight) {
                currentSection = id;
                break;
            }
        }

        const bottomOfPage = (window.innerHeight + scrollY) >= document.body.offsetHeight - 50;
        if (bottomOfPage) {
            for (let i = sectionIds.length - 1; i >= 0; i--) {
                if (document.getElementById(sectionIds[i])) {
                    currentSection = sectionIds[i];
                    break;
                }
            }
        }

        document.querySelectorAll<HTMLElement>("[data-section]").forEach(link => {
            if (link.dataset.section === currentSection) {
                link.classList.add("active");
            } else {
                link.classList.remove("active");
            }
        });
    }

    // Toggle mobile menu
    function toggleMenu() {
        const isOpen = mobileMenu?.classList.toggle("open");
        menuBtn?.classList.toggle("open", isOpen);
    }

    function closeMenu() {
        mobileMenu?.classList.remove("open");
        menuBtn?.classList.remove("open");
    }

    // Event listeners
    window.addEventListener("scroll", handleScroll, { passive: true });
    window.addEventListener("scroll", handleScrollSpy, { passive: true });
    menuBtn?.addEventListener("click", toggleMenu);

    // Close menu on mobile link click
    document.querySelectorAll(".mobile-link").forEach(link => {
        link.addEventListener("click", closeMenu);
    });

    // Init
    handleScroll();
    handleScrollSpy();
</script>
